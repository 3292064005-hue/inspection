{
  "name": "inspection-hmi-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js --mode mock",
    "dev:mock": "node ./node_modules/vite/bin/vite.js --mode mock",
    "dev:demo": "node ./node_modules/vite/bin/vite.js --mode demo",
    "dev:real": "node ./node_modules/vite/bin/vite.js --mode real",
    "typecheck": "node ./node_modules/vue-tsc/bin/vue-tsc.js --noEmit",
    "test": "node ./node_modules/vitest/vitest.mjs --run --pool=forks --poolOptions.forks.singleFork=true",
    "test:watch": "node ./node_modules/vitest/vitest.mjs --pool=forks --poolOptions.forks.singleFork=true",
    "coverage": "node ./node_modules/vitest/vitest.mjs --run --coverage",
    "build": "node ./node_modules/vue-tsc/bin/vue-tsc.js --noEmit && node ./node_modules/vite/bin/vite.js build --mode real",
    "build:mock": "node ./node_modules/vue-tsc/bin/vue-tsc.js --noEmit && node ./node_modules/vite/bin/vite.js build --mode mock",
    "build:demo": "node ./node_modules/vue-tsc/bin/vue-tsc.js --noEmit && node ./node_modules/vite/bin/vite.js build --mode demo",
    "build:real": "node ./node_modules/vue-tsc/bin/vue-tsc.js --noEmit && node ./node_modules/vite/bin/vite.js build --mode real",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "ci:check": "npm test && npm run typecheck && npm run lint && npm run build:real",
    "lint": "node ./node_modules/eslint/bin/eslint.js . --ext .ts,.vue",
    "lint:fix": "node ./node_modules/eslint/bin/eslint.js . --ext .ts,.vue --fix",
    "e2e": "node ./node_modules/@playwright/test/cli.js test",
    "ci:full": "npm test && npm run typecheck && npm run lint && npm run build:real && npm run e2e"
  },
  "dependencies": {
    "echarts": "^5.5.1",
    "pinia": "^2.1.7",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.13.10",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.25.1",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.4.0",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "vue-eslint-parser": "^10.1.3",
    "vue-tsc": "^2.2.8"
  }
}
